        "charges"
      ],
      "rules": [
        {
          "if": "staff_injured == true",
          "require": "company_nurse_confirmation_number",
          "question": "Company Nurse called at (877) 854-6877 - confirmation number?",
          "answer_type": "text",
          "blocking": true
        },
        {
          "if": "staff_injured == true",
          "require": "officer_accident_report_completed",
          "question": "Officer Accident Report completed?",
          "answer_type": "yes_no",
          "blocking": false,
          "on_yes": "check checklist box",
          "on_no": "leave checklist box unchecked"
        },
        {
          "if": "always",
          "require": "restraints_applied_by",
          "question": "Who placed hand restraints on the inmate (rank and name)?",
          "answer_type": "text",
          "blocking": true
        },
        {
          "if": "always",
          "require": "escorted_by",
          "question": "Who escorted the inmate (usually two officers - rank and name)?",
          "answer_type": "text",
          "blocking": true
        },
        {
          "if": "always",
          "require": "escort_destination",
          "question": "Escorted to?",
          "answer_type": "choice",
          "options_ref": "escort_destination",
          "blocking": true
        },
        {
          "if": "weapon_involved == true",
          "require": "weapon_custody_officer",
          "question": "Who took chain of custody of the weapon (F401)?",
          "answer_type": "text",
          "blocking": true
        },
        {
          "if": "always",
          "require": "photo_video_obtained",
          "question": "Photograph/video footage obtained?",
          "answer_type": "yes_no",
          "blocking": false,
          "on_yes": "check checklist box + insert attachment line",
          "on_no": "leave checklist box unchecked"
        }
      ],
      "auto_content": [
        {
          "id": "footage_attached",
          "insert_into": [
            "cover_letter"
          ],
          "condition": "photo_video_obtained == 'Yes'",
          "template": "Photograph/video footage of the incident is attached."
        },
        {
          "id": "company_nurse_line",
          "insert_into": [
            "cover_letter"
          ],
          "condition": "staff_injured == true",
          "template": "The Company Nurse line was contacted, confirmation number {company_nurse_confirmation_number}."
        },
        {
          "id": "restraint_escort_line",
          "insert_into": [
            "first_person",
            "supervisor_summary"
          ],
          "condition": "always",
          "template": "{restraints_applied_by} placed hand restraints onto {inmate} and {escorted_by} escorted him to {escort_destination}."
        }
      ]
    },
    {
      "name": "forced_cell_movement",
      "label": "Forced Cell Movement",
      "forms_required": [
        "cover_letter",
        "005_409",
        "major_disciplinary_form",
        "forced_cell_movement_fact_sheet",
        "photo_video",
        "chain_of_custody",
        "medical_report",
        "inmate_drug_test",
        "24_hour_review",
        "72_hour_review",
        "emergency_gate_pass_if_treated_outside"
      ],
      "reports": [
        "cover_letter",
        "first_person",
        "supervisor_summary",
        "disciplinary"
      ],
      "required_slots": [
        "date",
        "time",
        "location",
        "inmates_involved",
        "authorization",
        "orders_given",
        "video_recorded",
        "charges"
      ],
      "rules": [
        {
          "if": "always",
          "require": "authorization",
          "question": "Who authorized the forced cell movement?",
          "answer_type": "choice",
          "options": [
            "Shift Lieutenant",
            "Shift Captain",
            "Chief of Security",
            "Warden / Deputy Warden"
          ],
          "blocking": true
        },
        {
          "if": "always",
          "require": "orders_given",
          "question": "What direct orders were given before force was used, and how many times?",
          "answer_type": "text",
          "blocking": true
        },
        {
          "if": "always",
          "require": "video_recorded",
          "question": "Movement recorded on video? By whom?",
          "answer_type": "text",
          "blocking": true
        },
        {
          "if": "medical_disposition == 'Sent by ambulance to outside facility'",
          "require": "emergency_gate_pass",
          "question": "Emergency Gate Pass issued?",
          "answer_type": "yes_no",
          "blocking": false,
          "on_yes": "check checklist box",
          "on_no": "leave checklist box unchecked"
        },
        {
          "if": "always",
          "require": "photo_video_obtained",
          "question": "Photograph/video footage obtained?",
          "answer_type": "yes_no",
          "blocking": false,
          "on_yes": "check checklist box + insert attachment line",
          "on_no": "leave checklist box unchecked"
        }
      ],
      "auto_content": [
        {
          "id": "forced_cell_movement_line",
          "insert_into": [
            "first_person",
            "supervisor_summary"
          ],
          "condition": "always",
          "template": "A forced cell movement was authorized by {authorization}. Orders were given: {orders_given}. The use of force was video recorded by {video_recorded}."
        },
        {
          "id": "footage_attached",
          "insert_into": [
            "cover_letter"
          ],
          "condition": "photo_video_obtained == 'Yes'",
          "template": "Photograph/video footage of the incident is attached."
        }
      ]
    },
